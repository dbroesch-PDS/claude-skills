# Copy this file to .env or add these to your ~/.zshrc

# Your Spotify app's Client ID
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id_here

# The HTTPS redirect URI registered in your Spotify app dashboard
# For Block employees: deploy the Blockcell auth page and use its URL
# e.g. https://blockcell.sqprod.co/sites/YOUR-NAME-spotify-auth/
SPOTIFY_REDIRECT_URI=https://your-callback-url/
