{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "UUID": "com.dbroesch.githubprs",
  "Name": "GitHub PRs",
  "Version": "1.0.0",
  "SDKVersion": 2,
  "Author": "David Broesch",
  "Description": "Shows open GitHub pull requests assigned to you. Press to open GitHub PR page.",
  "Icon": "imgs/plugin/icon",
  "CodePath": "bin/plugin.js",
  "Software": { "MinimumVersion": "6.5" },
  "OS": [
    { "Platform": "mac", "MinimumVersion": "10.15" }
  ],
  "Nodejs": { "Version": "20", "Debug": "enabled" },
  "Actions": [
    {
      "UUID": "com.dbroesch.githubprs.openprlist",
      "Name": "Open PRs",
      "Tooltip": "Shows your open GitHub PRs. Press to open GitHub.",
      "Icon": "imgs/actions/openprlist/icon",
      "States": [
        { "Image": "imgs/actions/openprlist/key" }
      ],
      "Controllers": ["Keypad"],
      "PropertyInspectorPath": "ui/openprlist-pi.html"
    }
  ]
}
